  enum Piatto {
    NESSUNO
    SASHIMI
    URAMAKI_RAINBOW
    HOSOMAKI_MAGURO

    +getTempoDiPreparazione(): int
    +getImmaginePiatto(): URL
    +toString(): String
  }

  Piatto "1" --* "1" StatoTavolo : "piattoOrdinato"
  Piatto "1" --* "1" Cuoco : "piattoInPreparazione"
  Piatto "1" --* "1" TransferPiatto : "piatto"
  Piatto "*" --* "1" Sala : "piattiPronti"

  exception TavoloNonOccupatoException {}
  exception TavoloOccupatoException {}
  exception PiattoErratoException {
    +PiattoErratoException(String)
  }
}

