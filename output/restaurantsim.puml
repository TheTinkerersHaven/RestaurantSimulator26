Gioco "1" *-- "1" Sala : "sala"
Gioco "1" o-- "*" Notifica : "notifiche"
Gioco "1" o-- "3" Cuoco : "cuochi"
Gioco ..> Salvataggio : "carica/salva"
Cuoco ..> Cuoco : "copia"
Sala "1" o-- "4" Tavolo : "tavoli"
Tavolo ..> StatoTavolo : "genera"
Salvataggio "1" o-- "*" Notifica : "notifiche"
Salvataggio "1" o-- "3" Cuoco : "cuochi"
Salvataggio "1" o-- "4" StatoTavolo : "tavoli"
Salvataggio ..> Gioco : "stato"
PannelloSala "1" *-- "4" PannelloTavolo : "tavoli"
PannelloSala "1" *-- "1" BarraSuperiore : "barra"
PannelloSala ..> PiattoTransferHandle : "gestisce"
PannelloSala ..> ControllerNavigazione : "naviga"
PannelloSala ..> ControllerNotifiche : "notifica"
Finestra "1" *-- "1" PannelloPrincipale : "principale"
PannelloTavolo ..> StatoTavolo : "visualizza"
ClassificaPanel ..> ControllerNavigazione : "naviga"
NotificaPanel ..> ControllerNotifiche : "chiude"
NotificaPanel ..> Notifica : "mostra"
PannelloMenu ..> ControllerNavigazione : "naviga"
BarraSuperiore ..> ControllerNavigazione : "naviga"
BarraSuperiore ..> ControllerNotifiche : "notifiche"
PannelloCucina "1" *-- "1" BarraSuperiore : "barra"
PannelloCucina "1" *-- "3" PannelloCuoco : "cuochi"
PannelloCucina ..> ControllerNavigazione : "naviga"
PannelloCucina ..> ControllerNotifiche : "notifica"
PannelloPrincipale "1" *-- "1" PannelloMenu : "menu"
PannelloPrincipale "1" *-- "1" PannelloSala : "sala"
PannelloPrincipale "1" *-- "1" ClassificaPanel : "classifica"
PannelloPrincipale "1" *-- "1" PannelloImpostazioni : "impostazioni"
PannelloPrincipale "1" *-- "1" PannelloCucina : "cucina"
PannelloPrincipale ..> ControllerNavigazione : "naviga"
PannelloPrincipale ..> Notifica : "visualizza"
