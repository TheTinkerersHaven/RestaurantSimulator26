@startuml "Restaurant Simulator"

' Layout configuration
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 60
skinparam groupInheritance 2
skinparam packageStyle frame
skinparam pageMargin 100
hide empty members

' Forza il posizionamento relativo in alto (non usare package dentro together se già definiti sotto)
restaurantsim.model -[hidden]right- restaurantsim.controller

' Vincolo verticale forte verso la View
restaurantsim.model ---[hidden]down--- restaurantsim.view
restaurantsim.controller ---[hidden]down--- restaurantsim.view

skinparam package {
  BackgroundColor<<Model>> LightCyan
  BackgroundColor<<Main>> Linen
  BackgroundColor<<View>> Bisque
  BackgroundColor<<Controller>> IndianRed
}

